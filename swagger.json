        }
      }
    },
    "/api/users/{id}/onboarding/complete": {
      "post": {
        "summary": "Complete Onboarding Status",
        "description": "Finalizes the onboarding, changes the status flag, and optionally links GitHub.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User UUID string",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "githubId": { "type": "string", "example": "98765432" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Onboarding completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Onboarding completed successfully" },
                    "result": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "User not found or query error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "User not found" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}/profile": {
      "patch": {
        "summary": "Update Account Settings",
        "description": "Updates primary profile settings (First Name, Last Name, Email, and University).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User UUID string",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["first_name", "last_name", "email", "university"],
                "properties": {
                  "first_name": { "type": "string", "example": "Alex" },
                  "last_name": { "type": "string", "example": "Rahman" },
                  "email": { "type": "string", "format": "email", "example": "alex.rahman@email.com" },
                  "university": { "type": "string", "example": "Universitas Indonesia" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account settings updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Account settings updated successfully" },
                    "result": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameter inputs or email already registered by another account",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Email already registered by another account" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}/password": {
      "put": {
        "summary": "Update Password",
        "description": "Updates the user password. Current password is required if user has one.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User UUID string",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["new_password"],
                "properties": {
                  "current_password": { "type": "string", "example": "oldsecurepassword123" },
                  "new_password": { "type": "string", "minLength": 6, "example": "newsecurepassword456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Password updated successfully" },
                    "result": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Incorrect current password, or new password too short",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Incorrect current password" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/dashboard/summary": {
      "get": {
        "summary": "Get Dashboard Summary",
        "description": "Retrieves the dashboard summary for the currently authenticated user.",
        "tags": ["Web MVP"],
        "responses": {
          "200": {
            "description": "Dashboard summary retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Dashboard summary retrieved successfully" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "Ubay Dillah" },
                        "role": { "type": "string", "example": "Frontend Developer" },
                        "initials": { "type": "string", "example": "UD" },
                        "streak": { "type": "integer", "example": 3 },
                        "readinessScore": { "type": "integer", "example": 62 },
                        "readinessTrend": { "type": "string", "example": "+8%" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/readiness/skill-gap": {
      "get": {
        "summary": "Get Skill Gap Analysis",
        "description": "Retrieves the list of skill gaps between the user's current abilities and the requirements of their target role.",
        "tags": ["Web MVP"],
        "responses": {
          "200": {
            "description": "Skill gap retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Skill gap retrieved successfully" },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "skill": { "type": "string", "example": "React" },
                          "current": { "type": "integer", "example": 40 },
                          "required": { "type": "integer", "example": 80 },
                          "demand": { "type": "string", "example": "High" },
                          "priority": { "type": "string", "example": "Critical" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/readiness/market-demand": {
      "get": {
        "summary": "Get Market Demand",
        "description": "Retrieves market demand trends for various skills.",
        "tags": ["Web MVP"],
        "responses": {
          "200": {
            "description": "Market demand retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Market demand retrieved successfully" },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "rank": { "type": "integer", "example": 1 },
                          "skill": { "type": "string", "example": "JavaScript" },
                          "jobs_count": { "type": "integer", "example": 15000 },
                          "trend_score": { "type": "integer", "example": 95 },
                          "bar_width": { "type": "integer", "example": 95 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid", "example": "e0b5d55e-5fb2-4c28-bb7e-f637de2f06ba" },
          "email": { "type": "string", "format": "email", "example": "user@example.com" },
          "username": { "type": "string", "nullable": true, "example": "alex_rahman" },
          "first_name": { "type": "string", "nullable": true, "example": "Alex" },
          "last_name": { "type": "string", "nullable": true, "example": "Rahman" },
          "university": { "type": "string", "nullable": true, "example": "Universitas Indonesia" },
          "field_of_study": { "type": "string", "nullable": true, "example": "Computer Science" },
          "graduation_year": { "type": "integer", "nullable": true, "example": 2026 },
          "avatar_url": { "type": "string", "nullable": true, "example": "http://localhost:5001/uploads/avatar.png" },
          "achievement_goal": { "$ref": "#/components/schemas/AchievementGoal" },
          "target_role": { "type": "string", "nullable": true, "example": "Frontend Developer" },
          "cv_url": { "type": "string", "nullable": true, "example": "http://localhost:5001/uploads/cv_12345.pdf" },
          "transcript_url": { "type": "string", "nullable": true, "example": "http://localhost:5001/uploads/transcript_12345.pdf" },
          "onboarding_completed": { "type": "boolean", "example": false },
          "is_email_verified": { "type": "boolean", "example": false },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "AchievementGoal": {
        "type": "string",
        "nullable": true,
        "enum": [
          "GET_FIRST_JOB",
          "SWITCH_DEVELOPER_ROLE",
          "IMPROVE_CODING_SKILLS",
          "PREPARE_INTERVIEWS",
          "BUILD_PORTFOLIO",
          "UNDERSTAND_MARKET"
        ],
        "example": "GET_FIRST_JOB"
      }
    }
  }
}
