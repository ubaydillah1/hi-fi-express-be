                  "cv": { "type": "string", "format": "binary", "description": "CV File (PDF/Docs/Image)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CV uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "CV uploaded successfully" },
                    "result": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Upload failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "CV file is required" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}/onboarding/transcript": {
      "patch": {
        "summary": "Upload Academic Transcript",
        "description": "Uploads academic transcript only.",
        "parameters": [
          {
            "name": "id",
