# =========================================================================
# HI-FI EXPRESS BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and adjust the variables for your setup.
# =========================================================================

# 🖥️ Server Configurations
PORT=5000
NODE_ENV=development

# 🗄️ MySQL Database Configurations for Docker & Local Connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hifi_db
DB_USER=hifi_user
DB_PASSWORD=your_mysql_password_here
DB_ROOT_PASSWORD=your_mysql_root_password_here

# Database Connection URL (Format: mysql://[user]:[password]@[host]:[port]/[database_name])
DATABASE_URL=mysql://hifi_user:your_mysql_password_here@localhost:3306/hifi_db

# 🛡️ JWT Authentication Security Secrets
# Use high-entropy random strings for production tokens.
JWT_ACCESS_SECRET=your_jwt_access_token_secret_string_here
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_string_here

# 🔑 Google OAuth Client ID
# Generated from Google Cloud Console. Must match the Frontend client ID.
# Format: <client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# 📁 Application & File Upload Configuration
APP_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# 🐙 GitHub OAuth Configuration
# Generated from GitHub Developer Settings -> OAuth Apps.
GITHUB_CLIENT_ID=your_github_client_id_here
